    "@thenamespace/addresses": "^1.1.0",
    "@thenamespace/avatar": "^1.0.0",
    "@thenamespace/mint-manager": "^1.1.1",
    "@thenamespace/offchain-manager": "^1.0.10",
    "bootstrap": "^5.3.0",
