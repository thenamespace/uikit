    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "axios": "^1.11.0",
    "cssnano": "^7.1.1",
    "postcss-import": "^16.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.6",
    "rimraf": "^6.0.1",
    "rollup": "^4.50.1",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "typescript": "^5.9.2",
    "viem": "^2.46.3",
    "wagmi": "^2.19.5"
